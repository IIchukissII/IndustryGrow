
# KiCad local-history auto-backups (editor artifact, not project content)
store/.history/

# KiCad editor lock files (created while a file is open)
*.lck

# QElectroTech backup files (editor artifact, not project content)
*.qet.bak

# Draft ADRs (work-in-progress, not yet assigned a number)
ADR-*DRAFT*.md

# Python bytecode (e.g. from compiling the gateway/ self-test locally)
__pycache__/
*.pyc

# Firmware build artifacts (CMake build trees, Nunavut-generated code, binaries)
firmware/build*/
firmware/**/build*/
*.elf
*.o
*.d
