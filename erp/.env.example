# Copy to .env and adjust. All keys are prefixed ERP_.

# Operator identity — the single tenant (ADR-0021 d16)
ERP_OPERATOR_UUID=00000000-0000-0000-0000-000000000001
ERP_OPERATOR_NAME=OP-STRAWBERRY-01

# MongoDB — the document metadata store
ERP_MONGO_URI=mongodb://localhost:27017
ERP_MONGO_DB=industrygrow_erp

# Warehouse — S3-compatible object store (blobs; ADR-0017 d15).
# Same vars for MinIO / AWS S3 / Cloudflare R2 — only the values change.
# Prefer injecting the ACCESS_KEY/SECRET from 1Password (see .env.op.tpl),
# not hard-coding them here.
#   MinIO (IndustryFlow): ERP_WAREHOUSE_ENDPOINT=http://minio:9000
#   Cloudflare R2:        ERP_WAREHOUSE_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#                         ERP_WAREHOUSE_REGION=auto
ERP_WAREHOUSE_ENDPOINT=http://localhost:9000
ERP_WAREHOUSE_BUCKET=industrygrow
ERP_WAREHOUSE_ACCESS_KEY=minioadmin
ERP_WAREHOUSE_SECRET_KEY=minioadmin
ERP_WAREHOUSE_REGION=us-east-1

# Repo store/ — the public type-level flat keyspace synced into the warehouse
ERP_STORE_DIR=../store

# REGISTRY.md — the authoritative type registry, read not copied (ADR-0023)
ERP_REGISTRY_PATH=../REGISTRY.md

# The built console bundle, served at / (npm run build in frontend/)
ERP_CONSOLE_DIR=frontend/dist

# Gateway mTLS channel (ADR-0022 d2) — the addresses the TLS-terminating proxy
# appears as on the wire (IPs or CIDRs, JSON list). Forwarded certificate headers
# are believed from these and nowhere else. Empty = the gateway routes are closed
# (503), which is the safe default when nothing is terminating mTLS in front.
# See deploy/mtls/README.md.
#ERP_GATEWAY_TRUSTED_PROXIES=["172.16.0.0/12"]

# Web
ERP_HOST=0.0.0.0
ERP_PORT=8021
ERP_RELOAD=false
