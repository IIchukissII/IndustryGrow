# Copy to .env and adjust. All keys are prefixed ERP_.

# Operator identity — the single tenant (ADR-0021 d16)
ERP_OPERATOR_UUID=00000000-0000-0000-0000-000000000001
ERP_OPERATOR_NAME=OP-STRAWBERRY-01

# MongoDB — the document metadata store
ERP_MONGO_URI=mongodb://localhost:27017
ERP_MONGO_DB=industrygrow_erp

# Warehouse — S3-compatible object store (blobs; ADR-0017 d15)
ERP_WAREHOUSE_ENDPOINT=http://localhost:9000
ERP_WAREHOUSE_BUCKET=industrygrow
ERP_WAREHOUSE_ACCESS_KEY=minioadmin
ERP_WAREHOUSE_SECRET_KEY=minioadmin
ERP_WAREHOUSE_REGION=us-east-1

# Web
ERP_HOST=0.0.0.0
ERP_PORT=8021
ERP_RELOAD=false
