#
# IndustryGrow gateway provisioning configuration — TEMPLATE.
#
# Copy to gateway.env and edit, OR let provision.sh install this as
# /etc/industrygrow/gateway.env on first run (it will not overwrite your edits).
#
# THIS FILE CONTAINS NO SECRETS. Per-instance secrets — login/sudo password, SSH
# private keys, the future ATECC608 binding and gateway certificate — live
# OFF-REPO in a secret manager / IndustryFlow (ADR-0017 two-homes deferred item;
# ADR-0019 d2: the gateway's instance key is the vendor serial + the ATECC-bound
# cert, never committed here). The automation authenticates only by the SSH key
# already installed by the Imager.

# --- Network / SSH -----------------------------------------------------------
# LAN interface that SSH is allowed in on (ADR-0004 d6). LEAVE EMPTY to auto-detect
# the interface carrying the default route (the path you manage the Pi over) —
# lockout-safe, because eth0 is NOT a safe assumption: WiFi is wlan0 and recent
# kernels name onboard Ethernet end0 on Pi 5. Set explicitly only to override.
IGROW_LAN_IFACE=""
IGROW_SSH_PORT="22"

# --- CAN ---------------------------------------------------------------------
# IGROW_CAN_IFACE selects the interface the automation brings up (can-up.sh):
#   vcan0  — bring-up validation, software loopback, NO bit rate.
#   can0   — physical bus (after the HAT + overlay exist), brought up at the rate
#            below.
# IGROW_CAN_BITRATE is the single home for the bus rate. It is FIXED at 500000
# (500 kbit/s classic CAN, ADR-0002 rev 3 d8 — a single fixed rate, no
# negotiation); do not change it without an ADR amendment. It applies to a
# physical canN only; vcan ignores it.
IGROW_CAN_IFACE="vcan0"
IGROW_CAN_BITRATE="500000"

# Physical MCP2515 HAT overlay — OPTIONAL, flag-gated, OFF by default.
# Set IGROW_CAN_HAT=mcp2515 to have provision.sh manage the device-tree overlay
# in /boot/firmware/config.txt (declarative + idempotent). HAT-specific and needs
# a REBOOT before can0/can1 appear. The oscillator MUST match the crystal printed
# on the board; the INT GPIOs are board-specific. Leave IGROW_CAN1_INT empty for a
# single-channel HAT. Validated: Waveshare 2-CH Isolated CAN HAT = 16 MHz, can0
# INT25, can1 INT24.
# IGROW_CAN_HAT_SPI_MAXFREQ caps the MCP2515 SPI clock. REQUIRED on the Pi 5 (RP1):
# the default clock is too fast and corrupts the register reads that clear the INT
# flag, so the interrupt storms and the driver never delivers received frames — RX
# is dead while init/TX still look fine (MCP2515 internal loopback exposes it). 1 MHz
# is reliable; set empty to use the driver default (fine on Pi 4 / older).
IGROW_CAN_HAT="off"          # off | mcp2515
IGROW_CAN_HAT_OSC="16000000"
IGROW_CAN0_INT="25"
IGROW_CAN1_INT="24"          # empty = single-channel (can0 only)
IGROW_CAN_HAT_SPI_MAXFREQ="1000000"  # Hz; REQUIRED on Pi 5. empty = driver default

# --- Unattended-upgrades reboot window (ADR-0004 d4) -------------------------
# FLAGGED: ADR-0004 d4 schedules the reboot "during photoperiod-off hours", which
# is UNDEFINED before a cultivation profile exists. LEAVE EMPTY to keep automatic
# reboot DISABLED (default). Set to "HH:MM" only once the photoperiod is known.
IGROW_UNATTENDED_REBOOT_TIME=""

# --- Local persistent store (ADR-0020) ---------------------------------------
# OFF by default: on the SD bring-up card the gateway is RAM-only (ADR-0004 d8-9;
# ADR-0020 d10 allows bare SD only for no-local-store deployments). Set to "on"
# ONLY on an SSD/NVMe medium, where ADR-0020 d2/d3 permits the bounded best-effort
# store-and-forward buffer. The on-disk format/retention are ADR-0020 deferred
# items — this flag only gates whether the StateDirectory buffer is used.
IGROW_PERSISTENT_BUFFER="off"

# --- Production egress target (ADR-0004 d5) — NOT applied at bring-up ---------
# Documentation only: when IndustryFlow exists (roadmap stage 11), this is the
# endpoint egress is locked to. Empty now; bring-up keeps egress open.
IGROW_INDUSTRYFLOW_ENDPOINT=""

# --- pip hash enforcement (see requirements.txt) -----------------------------
# Set to 1 after generating requirements.lock on the target arch.
IGROW_REQUIRE_HASHES="0"
